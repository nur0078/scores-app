{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/fd/(.*)",
      "destination": "/api/football?path=$1"
    },
    {
      "source": "/api/tsdb/(.*)",
      "destination": "/api/thesportsdb?path=$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
